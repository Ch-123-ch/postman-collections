    {
      "name": "查询号码获取城市名",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "var jsonData=pm.response.json()\r",
              "var city=jsonData.data.province\r",
              "pm.globals.set(\"glb_city\",city)\r",
              ""
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "https://cx.shouji.360.cn/phonearea.php?number=13012345678",
          "protocol": "https",
          "host": [
            "cx",
            "shouji",
            "360",
            "cn"
          ],
          "path": [
            "phonearea.php"
          ],
          "query": [
            {
              "key": "number",
              "value": "13012345678"
            }
          ]
        }
      },
      "response": []
    },
    {
